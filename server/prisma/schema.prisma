generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int            @id @default(autoincrement())
  email         String         @unique
  password      String
  createdAt     DateTime       @default(now())
  studySessions StudySession[]
  moodLogs      MoodLog[]
  tasks         Task[]
}

model StudySession {
  id            Int       @id @default(autoincrement())
  userId        Int
  user          User      @relation(fields: [userId], references: [id])
  date          DateTime  @default(now())
  durationMins  Int
  mode          String
  moodBefore    Int?
  energyBefore  Int?
  focusQuality  Int?
  dominantState String?
  createdAt     DateTime  @default(now())
}

model MoodLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  date      DateTime @default(now())
  mood      Int
  energy    Int
  stress    Int
  note      String?
  createdAt DateTime @default(now())
}

model Task {
  id             Int       @id @default(autoincrement())
  userId         Int
  user           User      @relation(fields: [userId], references: [id])
  title          String
  subject        String
  deadline       DateTime?
  priority       String    @default("Medium") // High, Medium, Low
  status         String    @default("todo") // todo, inprogress, done
  estimatedHours Int?
  createdAt      DateTime  @default(now())
}